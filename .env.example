# === Required ===
OPENAI_API_KEY=sk-your-openai-api-key-here
SECRET_KEY=your-random-secret-key-change-this-to-something-long-and-random

# === Environment ===
ENVIRONMENT=development
DEBUG=true

# === Railway Deployment ===
# RAILWAY_VOLUME_DIR=/data
# ALLOWED_ORIGINS=https://your-app.up.railway.app
# PORT is auto-injected by Railway — do not set manually

# === Optional: Cloudinary (Video Scouting) ===
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# === Optional: SMTP (Email) ===
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
